# Google Gemini API Configuration
# Get your API key from: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Confluence Configuration (Optional - for importing requirements from Confluence)
# URL should be your Atlassian domain, e.g., https://your-company.atlassian.net
CONFLUENCE_URL=
# The email address you use to log in to Atlassian
CONFLUENCE_EMAIL=
# Generate API token at: https://id.atlassian.com/manage-profile/security/api-tokens
CONFLUENCE_API_TOKEN=
