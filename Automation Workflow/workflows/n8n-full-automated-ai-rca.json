{
    "name": "Playwright Fully Automated AI-RCA Workflow",
    "nodes": [
        {
            "parameters": {},
            "id": "trigger",
            "name": "Manual Trigger",
            "type": "n8n-nodes-base.manualTrigger",
            "typeVersion": 1,
            "position": [
                0,
                300
            ]
        },
        {
            "parameters": {
                "jsCode": "const fs = require('fs');\nconst path = require('path');\nconst SELECTED_PRODUCT = 'ERP'; // Change this to 'Camp' or others as needed\nconst resultsDir = 'c:/Users/veeramani/.gemini/antigravity/scratch/Automation Workflow/temp_results';\n\nif (fs.existsSync(resultsDir)) {\n  fs.readdirSync(resultsDir).forEach(f => { try { fs.unlinkSync(path.join(resultsDir, f)); } catch (e) {} });\n} else {\n  fs.mkdirSync(resultsDir, { recursive: true });\n}\n\nconst products = {\n  'ERP': { product: 'ERP', folder: 'ERP' },\n  'Camp': { product: 'Camp', folder: 'CampAccomodation' }\n};\nreturn [{ json: products[SELECTED_PRODUCT] }];"
            },
            "id": "init_cleanup",
            "name": "Init & Cleanup",
            "type": "n8n-nodes-base.code",
            "typeVersion": 2,
            "position": [
                200,
                300
            ]
        },
        {
            "parameters": {
                "jsCode": "const fs = require('fs');\nconst product = $input.item.json.product;\nconst folder = $input.item.json.folder;\nconst fullPath = `c:/Users/veeramani/.gemini/antigravity/scratch/Automation Workflow/tests/${folder}`;\n\nconst testFiles = fs.readdirSync(fullPath).filter(f => f.endsWith('.spec.js'));\nreturn testFiles.map(f => ({\n    json: {\n        product, \n        folder, \n        filename: f, \n        testPath: `tests/${folder}/${f}`\n    }\n}));"
            },
            "id": "find_tests",
            "name": "Find Test Files",
            "type": "n8n-nodes-base.code",
            "typeVersion": 2,
            "position": [
                450,
                300
            ]
        },
        {
            "parameters": {
                "batchSize": 1
            },
            "id": "test_loop",
            "name": "Test Loop",
            "type": "n8n-nodes-base.splitInBatches",
            "typeVersion": 1,
            "position": [
                700,
                300
            ]
        },
        {
            "parameters": {
                "jsCode": "const { execSync } = require('child_process');\nconst item = $input.item.json;\nconst cmd = `npx playwright test \"${item.testPath}\" --reporter=json`;\nconst cwd = 'c:/Users/veeramani/.gemini/antigravity/scratch/Automation Workflow';\nconst startTime = new Date();\nlet stdout = '', stderr = '', exitCode = 0;\n\ntry {\n  stdout = execSync(cmd, { cwd, stdio: 'pipe', timeout: 600000 }).toString();\n} catch (e) {\n  exitCode = e.status || 1;\n  stdout = (e.stdout || '').toString();\n  stderr = (e.stderr || e.message || '').toString();\n}\n\nconst duration = ((new Date() - startTime) / 1000).toFixed(2);\nlet screenshotPath = null;\ntry {\n  const jsonMatch = stdout.match(/\\{[\\s\\S]*\\}/);\n  if (jsonMatch) {\n    const jsonData = JSON.parse(jsonMatch[0]);\n    jsonData.suites?.forEach(s => s.specs?.forEach(sp => sp.tests?.forEach(t => {\n        const att = t.results?.[0]?.attachments?.find(a => a.name === 'screenshot');\n        if (att && !screenshotPath) screenshotPath = att.path;\n    })));\n  }\n} catch (e) {}\n\nconst combined = (stdout + '\\n' + stderr).trim();\nconst jsonStart = combined.lastIndexOf('{\"stats\":');\nconst logs = jsonStart !== -1 ? combined.substring(0, jsonStart).trim() : combined.trim();\n\nreturn { \n    json: { \n        ...item, \n        status: exitCode === 0 ? 'passed' : 'failed', \n        duration: `${duration}s`, \n        errorLogs: logs || 'Passed', \n        screenshotPath: screenshotPath ? (screenshotPath.includes(':') || screenshotPath.startsWith('/') ? screenshotPath : `${cwd}/${screenshotPath}`).replace(/\\\\/g, '/') : null \n    } \n};"
            },
            "id": "run_test_node",
            "name": "Run Playwright Test",
            "type": "n8n-nodes-base.code",
            "typeVersion": 2,
            "position": [
                950,
                300
            ]
        },
        {
            "parameters": {
                "conditions": {
                    "string": [
                        {
                            "value1": "={{ $json.status }}",
                            "operation": "equal",
                            "value2": "failed"
                        }
                    ]
                }
            },
            "id": "check_status",
            "name": "Passed or Failed?",
            "type": "n8n-nodes-base.if",
            "typeVersion": 1,
            "position": [
                1200,
                300
            ]
        },
        {
            "parameters": {
                "jsCode": "const fs = require('fs');\nconst path = require('path');\nconst testData = $node[\"Run Playwright Test\"].json;\nconst resultsDir = 'c:/Users/veeramani/.gemini/antigravity/scratch/Automation Workflow/temp_results';\nconst resultFile = path.join(resultsDir, `test_${Date.now()}_${testData.filename}.json`);\nfs.writeFileSync(resultFile, JSON.stringify(testData, null, 2));\nreturn { json: testData };"
            },
            "id": "save_result",
            "name": "Save Result",
            "type": "n8n-nodes-base.code",
            "typeVersion": 2,
            "position": [
                1400,
                500
            ]
        },
        {
            "parameters": {
                "jsCode": "const rawError = $json.errorLogs || '';\nconst cleanError = rawError.replace(/[\\u001b\\u009b][[\\]()#;?]*(?:(?:(?:[a-zA-Z\\\\d]*(?:;[-a-zA-Z\\\\d\\/#&.:=?%@~_]*)*)?\\u0007)|(?:(?:\\d{1,4}(?:;\\d{0,4})*)?[\\dA-PR-TZcf-ntqry=><~]))/g, '');\nreturn { json: { ...$json, cleanError: cleanError.substring(0, 3000) } };"
            },
            "id": "clean_logs",
            "name": "RCA: Clean Logs",
            "type": "n8n-nodes-base.code",
            "typeVersion": 2,
            "position": [
                1450,
                150
            ]
        },
        {
            "parameters": {
                "method": "POST",
                "url": "https://generativelanguage.googleapis.com/v1/models/gemini-2.5-flash:generateContent?key=[REDACTED_GEMINI_KEY]",
                "sendBody": true,
                "jsonBody": "={{ JSON.stringify({\n  \"contents\": [\n    {\n      \"parts\": [\n        {\n          \"text\": \"Analyze this Playwright failure and provide a 3-sentence summary for a developer.\\nFile: \" + ($json.filename || \"Unknown\") + \"\\nError: \" + ($json.cleanError || \"Unknown Error\") + \"\\n\\nFormat:\\n🔍 Analysis: ...\\n🛠️ Recommendation: ...\"\n        }\n      ]\n    }\n  ]\n}) }}"
            },
            "id": "gemini_rca",
            "name": "RCA: AI Analysis",
            "type": "n8n-nodes-base.httpRequest",
            "typeVersion": 3,
            "position": [
                1650,
                150
            ],
            "retryOnFail": true,
            "maxTries": 5,
            "waitBetweenTries": 5000
        },
        {
            "parameters": {
                "method": "POST",
                "url": "https://chat.googleapis.com/v1/spaces/AAQA7T2tWaY/messages?key=[REDACTED_GEMINI_KEY]&token=C0TOQS1FN_tbUfIeUHwat0Zwa9UXylCX97CKTIO4PKI",
                "sendBody": true,
                "bodyParameters": {
                    "parameters": [
                        {
                            "name": "text",
                            "value": "={{ '🤖 *Failed:* ' + $node[\"RCA: Clean Logs\"].json.filename + '\\n' + $json.candidates[0].content.parts[0].text }}"
                        }
                    ]
                }
            },
            "id": "chat_failure",
            "name": "Chat: Failure + RCA",
