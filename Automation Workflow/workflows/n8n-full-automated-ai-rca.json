            "typeVersion": 1,
            "position": [
                1850,
                200
            ]
        },
        {
            "parameters": {
                "resource": "message",
                "operation": "send",
                "email": "veeramani.b@algosium.com",
                "subject": "={{ '🚨 Failed: ' + $node[\"RCA: Clean Logs\"].json.filename }}",
                "emailType": "html",
                "message": "={{ '<h3>AI Root Cause Analysis</h3>' + $node[\"RCA: AI Analysis\"].json.candidates[0].content.parts[0].text + '<h3>Full Error Log</h3><pre>' + $node[\"RCA: Clean Logs\"].json.cleanError + '</pre>' }}",
                "attachmentsUi": {
