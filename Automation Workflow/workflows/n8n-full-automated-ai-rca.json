        {
            "parameters": {
                "method": "POST",
                "url": "https://chat.googleapis.com/v1/spaces/AAQA7T2tWaY/messages?key=[REDACTED_GEMINI_KEY]&token=C0TOQS1FN_tbUfIeUHwat0Zwa9UXylCX97CKTIO4PKI",
                "sendBody": true,
                "bodyParameters": {
                    "parameters": [
                        {
                            "name": "text",
                            "value": "={{ '✅ *Passed:* ' + $json.filename + ' (' + $json.duration + ')' }}"
                        }
                    ]
                }
            },
            "id": "chat_passed",
            "name": "Chat: Success",
            "type": "n8n-nodes-base.httpRequest",
            "typeVersion": 3,
            "position": [
                1450,
                450
            ]
        },
        {
            "parameters": {
                "jsCode": "const fs = require('fs');\nconst path = require('path');\nconst resultsDir = 'c:/Users/veeramani/.gemini/antigravity/scratch/Automation Workflow/temp_results';\nif (!fs.existsSync(resultsDir)) return { json: { summary: 'No results found' } };\nconst files = fs.readdirSync(resultsDir);\nlet passed = 0, failed = 0, table = '<table border=\"1\"><tr><th>File</th><th>Status</th><th>Duration</th></tr>';\nfiles.forEach(f => {\n  const data = JSON.parse(fs.readFileSync(path.join(resultsDir, f)));\n  if (data.status === 'passed') passed++; else failed++;\n  table += `<tr><td>${data.filename}</td><td>${data.status}</td><td>${data.duration}</td></tr>`;\n});\ntable += '</table>';\nreturn { json: { passed, failed, total: files.length, htmlTable: table } };"
            },
            "id": "final_summary_report",
            "name": "Final Summary Report",
            "type": "n8n-nodes-base.code",
            "typeVersion": 2,
            "position": [
                900,
