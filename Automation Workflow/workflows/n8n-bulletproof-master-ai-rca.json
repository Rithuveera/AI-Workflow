{
    "name": "MASTER V3 - Playwright Final Stable",
    "nodes": [
        {
            "parameters": {},
            "id": "trigger",
            "name": "Manual Trigger",
            "type": "n8n-nodes-base.manualTrigger",
            "typeVersion": 1,
            "position": [
                0,
                300
            ]
        },
        {
            "parameters": {
                "jsCode": "const fs = require('fs');\nconst path = require('path');\nconst resultsDir = 'c:/Users/veeramani/.gemini/antigravity/scratch/Automation Workflow/temp_results';\n\nif (fs.existsSync(resultsDir)) {\n  const files = fs.readdirSync(resultsDir).filter(f => f.endsWith('.json'));\n  for (const file of files) { try { fs.unlinkSync(path.join(resultsDir, file)); } catch (e) {} }\n} else {\n  fs.mkdirSync(resultsDir, { recursive: true });\n}\n\nreturn [{ json: { product: 'ERP', folder: 'ERP' } }];"
            },
            "id": "init",
            "name": "Init & Cleanup",
            "type": "n8n-nodes-base.code",
            "typeVersion": 2,
            "position": [
                200,
                300
            ]
        },
        {
            "parameters": {
                "jsCode": "const fs = require('fs');\nconst folder = $json.folder;\nconst fullPath = `c:/Users/veeramani/.gemini/antigravity/scratch/Automation Workflow/tests/${folder}`;\nconst allFiles = fs.readdirSync(fullPath).filter(f => f.endsWith('.spec.js'));\n// ⚡ QUICK RUN: Change 2 to total for bulk\nconst testFiles = allFiles.slice(0, 2);\n\nreturn testFiles.map(f => ({\n    json: {\n        product: $json.product, \n        filename: f, \n        testPath: `tests/${folder}/${f}`\n    }\n}));"
            },
            "id": "find_tests",
            "name": "Find Test Files",
            "type": "n8n-nodes-base.code",
            "typeVersion": 2,
            "position": [
                450,
                300
            ]
        },
        {
            "parameters": {
                "batchSize": 1
            },
            "id": "test_loop",
            "name": "Test Loop",
            "type": "n8n-nodes-base.splitInBatches",
            "typeVersion": 1,
            "position": [
                700,
                300
            ]
        },
        {
            "parameters": {
                "jsCode": "const { execSync } = require('child_process');\nconst item = $input.item.json;\nconst cmd = `npx playwright test \"${item.testPath}\" --reporter=json`;\nconst cwd = 'c:/Users/veeramani/.gemini/antigravity/scratch/Automation Workflow';\nconst startTime = new Date();\nlet stdout = '', stderr = '', exitCode = 0;\n\ntry {\n  stdout = execSync(cmd, { cwd, stdio: 'pipe', timeout: 600000 }).toString();\n} catch (e) {\n  exitCode = e.status || 1;\n  stdout = (e.stdout || '').toString();\n  stderr = (e.stderr || e.message || '').toString();\n}\n\nconst duration = ((new Date() - startTime) / 1000).toFixed(2);\nlet screenshotPath = '';\ntry {\n  const jsonMatch = stdout.match(/\\{[\\s\\S]*\\}/);\n  if (jsonMatch) {\n    const jsonData = JSON.parse(jsonMatch[0]);\n    jsonData.suites?.forEach(s => s.specs?.forEach(sp => sp.tests?.forEach(t => {\n        const att = t.results?.[0]?.attachments?.find(a => a.name === 'screenshot');\n        if (att) screenshotPath = att.path;\n    })));\n  }\n} catch (e) {}\n\nconst rawLogs = (stdout + '\\n' + stderr).trim();\nconst cleanLogs = rawLogs.replace(/[\\u001b\\u009b][[\\]()#;?]*(?:(?:(?:[a-zA-Z\\\\d]*(?:;[-a-zA-Z\\\\d\\/#&.:=?%@~_]*)*)?\\u0007)|(?:(?:\\d{1,4}(?:;\\d{0,4})*)?[\\dA-PR-TZcf-ntqry=><~]))/g, '');\n\nreturn { \n    json: { \n        ...item, \n        status: exitCode === 0 ? 'passed' : 'failed', \n        duration: `${duration}s`, \n        errorLogs: cleanLogs.substring(0, 3500), \n        screenshotPath: screenshotPath ? (screenshotPath.includes(':') ? screenshotPath : `${cwd}/${screenshotPath}`).replace(/\\\\/g, '/') : '' \n    } \n};"
            },
            "id": "run_test",
            "name": "Run Playwright Test",
            "type": "n8n-nodes-base.code",
            "typeVersion": 2,
            "position": [
                950,
                200
            ]
        },
        {
            "parameters": {
                "conditions": {
                    "string": [
                        {
                            "value1": "={{ $json.status }}",
                            "operation": "equal",
                            "value2": "failed"
                        }
                    ]
                }
            },
            "id": "is_failed",
            "name": "Is Failed?",
            "type": "n8n-nodes-base.if",
            "typeVersion": 1,
            "position": [
                1200,
                200
            ]
        },
        {
            "parameters": {
                "jsCode": "const payload = {\n  contents: [{\n    parts: [{\n      text: `Analyze this automation failure (3 sentences max):\\nFile: ${$json.filename}\\nError:\\n${$json.errorLogs}\\n\\nFormat:\\n\ud83d\udd0d Analysis: ...\\n\ud83d\udee0\ufe0f Recommendation: ...`\n    }]\n  }]\n};\nreturn { json: { payload: JSON.stringify(payload) } };"
            },
            "id": "prep_ai",
            "name": "Prep AI Body",
            "type": "n8n-nodes-base.code",
            "typeVersion": 2,
            "position": [
                1400,
                100
            ]
        },
        {
            "parameters": {
                "method": "POST",
                "url": "https://generativelanguage.googleapis.com/v1beta/models/gemini-1.5-flash:generateContent?key=[REDACTED_GEMINI_KEY]",
                "sendBody": true,
                "contentType": "json",
                "specifyBody": "string",
                "body": "={{ $json.payload }}",
                "options": {}
            },
            "id": "gemini_rca",
            "name": "AI RCA: Gemini",
            "type": "n8n-nodes-base.httpRequest",
            "typeVersion": 3,
            "position": [
                1600,
                100
            ],
            "onError": "continueErrorOutput"
        },
        {
            "parameters": {
                "method": "POST",
                "url": "https://chat.googleapis.com/v1/spaces/AAQA7T2tWaY/messages?key=[REDACTED_GEMINI_KEY]&token=C0TOQS1FN_tbUfIeUHwat0Zwa9UXylCX97CKTIO4PKI",
                "sendBody": true,
                "specifyBody": "json",
                "jsonBody": "={ \"text\": \"\ud83e\udd16 *FAILED:* {{ $node[\\\"Run Playwright Test\\\"].json.filename }}\\n{{ $json.candidates ? $json.candidates[0].content.parts[0].text : '\u26a0\ufe0f AI Analysis Unavailable' }}\" }"
            },
            "id": "chat_fail",
            "name": "Google Chat: RCA",
            "type": "n8n-nodes-base.httpRequest",
            "typeVersion": 3,
            "position": [
                1850,
                50
            ]
        },
        {
            "parameters": {
                "conditions": {
                    "string": [
                        {
                            "value1": "={{ $node[\"Run Playwright Test\"].json.screenshotPath }}",
                            "operation": "notEqual",
                            "value2": ""
                        }
                    ]
                }
            },
            "id": "has_ss",
