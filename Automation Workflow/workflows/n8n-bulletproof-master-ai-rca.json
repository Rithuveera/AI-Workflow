            "type": "n8n-nodes-base.readBinaryFile",
            "typeVersion": 1,
            "position": [
                2050,
                100
            ]
        },
        {
            "parameters": {
                "resource": "message",
                "operation": "send",
                "email": "veeramani.b@algosium.com",
                "subject": "={{ '\ud83d\udea8 Failed: ' + $node[\"Run Playwright Test\"].json.filename }}",
                "emailType": "html",
                "message": "={{ '<h3>AI Root Cause Analysis</h3>' + ($node[\"AI RCA: Gemini\"].json.candidates ? $node[\"AI RCA: Gemini\"].json.candidates[0].content.parts[0].text : 'AI skipped.') + '<h3>Logs</h3><pre>' + $node[\"Run Playwright Test\"].json.errorLogs + '</pre>' }}",
                "attachmentsUi": {
                    "attachmentsValues": [
                        {
                            "binaryPropertyName": "data"
                        }
                    ]
                }
            },
            "id": "gmail_fail",
            "name": "Gmail: Detailed Failure",
            "type": "n8n-nodes-base.gmail",
            "typeVersion": 2,
            "position": [
                2300,
                150
            ]
        },
        {
            "parameters": {
                "jsCode": "const fs = require('fs');\nconst path = require('path');\nconst d = $node[\"Run Playwright Test\"].json;\nconst dir = 'c:/Users/veeramani/.gemini/antigravity/scratch/Automation Workflow/temp_results';\nfs.writeFileSync(path.join(dir, `res_${Date.now()}.json`), JSON.stringify(d));\nreturn { json: d };"
            },
            "id": "save",
            "name": "Save Result",
            "type": "n8n-nodes-base.code",
            "typeVersion": 2,
            "position": [
                2600,
                300
            ]
        },
        {
            "parameters": {
                "method": "POST",
                "url": "https://chat.googleapis.com/v1/spaces/AAQA7T2tWaY/messages?key=[REDACTED_GEMINI_KEY]&token=C0TOQS1FN_tbUfIeUHwat0Zwa9UXylCX97CKTIO4PKI",
                "sendBody": true,
                "specifyBody": "json",
                "jsonBody": "={ \"text\": \"\u2705 *PASSED:* {{ $json.filename }}\" }"
            },
            "id": "chat_pass",
            "name": "Chat: Success",
            "type": "n8n-nodes-base.httpRequest",
            "typeVersion": 3,
            "position": [
                1400,
                350
            ]
        },
        {
            "parameters": {
                "jsCode": "const fs = require('fs');\nconst path = require('path');\nconst dir = 'c:/Users/veeramani/.gemini/antigravity/scratch/Automation Workflow/temp_results';\nconst files = fs.readdirSync(dir);\nlet p = 0, f = 0, rows = '';\nfiles.forEach(file => {\n  const d = JSON.parse(fs.readFileSync(path.join(dir, file)));\n  if (d.status === 'passed') p++; else f++;\n  rows += `<tr><td>${d.filename}</td><td>${d.status}</td></tr>`;\n});\nreturn { json: { total: files.length, passed: p, failed: f, table: rows } };"
            },
            "id": "summary",
            "name": "Final Summary",
            "type": "n8n-nodes-base.code",
            "typeVersion": 2,
            "position": [
                950,
                550
            ]
        },
        {
            "parameters": {
                "resource": "message",
                "operation": "send",
                "email": "veeramani.b@algosium.com",
                "subject": "Final Test Run Summary",
                "emailType": "html",
                "message": "={{ '<h2>Final Results</h2><p>Passed: ' + $json.passed + ' | Failed: ' + $json.failed + '</p><table>' + $json.table + '</table>' }}"
            },
            "id": "gmail_final",
            "name": "Gmail: Master Summary",
            "type": "n8n-nodes-base.gmail",
            "typeVersion": 2,
            "position": [
                1150,
                550
            ]
        }
