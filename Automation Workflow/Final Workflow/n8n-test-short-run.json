        },
        {
            "parameters": {
                "resource": "message",
                "operation": "send",
                "email": "veeramani.b@algosium.com",
                "subject": "={{ '📊 Consolidated Test Summary - ' + $json.successRate }}",
                "emailType": "html",
                "message": "={{ \"<html><body><h2>📊 ERP Test Summary</h2><p><strong>Total:</strong> \" + $json.total + \"</p><p><strong>✅ Passed:</strong> \" + $json.passed + \"</p><p><strong>❌ Failed:</strong> \" + $json.failed + \"</p><p><strong>Success Rate:</strong> \" + $json.successRate + \"</p></body></html>\" }}"
            },
            "id": "gmail_summary",
            "name": "Gmail Summary",
            "type": "n8n-nodes-base.gmail",
            "typeVersion": 2,
            "position": [
                1450,
                600
            ]
        }
